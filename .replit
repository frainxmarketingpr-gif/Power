# Configuracion de Replit — Simulador Powerball (modules-based, Python 3.11)
# Al pulsar Run: instala dependencias ligeras y levanta la interfaz Streamlit
# (visible en el webview). Ver alternativas (API/CLI) al final.

entrypoint = "main.py"
modules = ["python-3.11"]

run = "pip install -q -r requirements-lite.txt && streamlit run pb_engine/app.py --server.port 8080 --server.address 0.0.0.0 --server.headless true"

[env]
PYTHONUNBUFFERED = "1"
NUMBA_CACHE_DIR = "/tmp/numba_cache"

[[ports]]
localPort = 8080
externalPort = 80

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "pip install -q -r requirements-lite.txt && streamlit run pb_engine/app.py --server.port 8080 --server.address 0.0.0.0 --server.headless true"]

# --- Alternativas (cambia la linea `run` de arriba, o usa el Shell) ---
# Analisis por consola:  python main.py
# API REST:              pip install -r requirements-lite.txt && uvicorn pb_engine.api:app --host 0.0.0.0 --port 8080
# Tests:                 pip install -r requirements-lite.txt pytest && pytest -q
